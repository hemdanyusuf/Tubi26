  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c green,cyan \"npm:server\" \"npm:frontend\"",
    "frontend": "vite --port=3000 --host=0.0.0.0",
    "server": "python backend/app.py",
