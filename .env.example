# API (Express)
API_PORT=3001

# Frontend (Vite)
VITE_GEMINI_API_KEY=your_gemini_api_key

# SQL Server — kullanıcı/şifre ile
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=YourDatabase
MSSQL_USER=sa
MSSQL_PASSWORD=your_password

# Yerel geliştirme: sunucu sertifikası güvenilmezse true bırakın
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERTIFICATE=true

# Windows kimlik doğrulaması (MSSQL_USER / MSSQL_PASSWORD gerekmez)
# MSSQL_USE_WINDOWS_AUTH=true
